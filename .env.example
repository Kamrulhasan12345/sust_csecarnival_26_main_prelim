# Priority 1: Custom local OpenAI-compatible API (e.g. LM Studio, Ollama, vLLM)
# If CUSTOM_API_URL is set, this backend is tried first.
CUSTOM_API_URL=
CUSTOM_API_KEY=auto
CUSTOM_MODEL=auto

# Priority 2: Groq free API (fallback if custom API is unavailable or unset)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Per-request LLM timeout in seconds (bounded so the LLM path can never approach
# the 30s judging limit). Worst case latency = number_of_backends * LLM_TIMEOUT.
LLM_TIMEOUT=8
LLM_MAX_TOKENS=400

# Service port
PORT=8000
